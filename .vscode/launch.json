{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "CliManager: auth",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/CliManager/bin/Debug/net8.0/CliManager.dll",
      "args": ["auth"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "DOTNET_ENVIRONMENT": "Development"
      }
    },
    {
      "name": "CliManager: upload",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/CliManager/bin/Debug/net8.0/CliManager.dll",
      "args": ["upload", "Downloads/example.txt", "Uploads"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "CliManager: search",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/CliManager/bin/Debug/net8.0/CliManager.dll",
      "args": ["search", "test"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "DOTNET_ENVIRONMENT": "Development"
      }
    },
    {
      "name": "CliManager: sync",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/CliManager/bin/Debug/net8.0/CliManager.dll",
      "args": ["sync"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "CliManager: help",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/CliManager/bin/Debug/net8.0/CliManager.dll",
      "args": ["--help"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ]
}
